page {
  background:
    radial-gradient(circle at top right, rgba(255, 193, 119, 0.18), transparent 28%),
    linear-gradient(180deg, #f8f1e8 0%, #eef4f8 100%);
  color: #1f2d3d;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.hero {
  margin-bottom: 28rpx;
}

.eyebrow {
  display: block;
  margin-bottom: 14rpx;
  color: #a06130;
  font-size: 24rpx;
  letter-spacing: 4rpx;
}

.title {
  display: block;
  margin-bottom: 14rpx;
  color: #1c2b38;
  font-size: 46rpx;
  font-weight: 600;
}

.desc {
  display: block;
  color: #536274;
  line-height: 1.7;
}

.card,
.panel,
.state-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 56rpx rgba(31, 45, 61, 0.08);
}

.section-title {
  display: block;
  margin-bottom: 12rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #1d2a3a;
}

.section-desc {
  display: block;
  margin-bottom: 20rpx;
  color: #5b6b7f;
  line-height: 1.6;
}

.field {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  color: #425466;
}

.input,
.textarea {
  width: 100%;
  min-height: 88rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  background: #f5f7fb;
  box-sizing: border-box;
}

.textarea {
  min-height: 220rpx;
}

.compact-field {
  margin-bottom: 16rpx;
}

.field-row {
  display: flex;
  gap: 16rpx;
}

.field-half {
  flex: 1;
}

.button-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
}

.primary-btn,
.secondary-btn,
.danger-btn {
  margin-top: 16rpx;
  border-radius: 18rpx;
}

.primary-btn {
  background: #c86c31;
  color: #ffffff;
}

.secondary-btn {
  background: #f0dfcf;
  color: #9d6432;
}

.danger-btn {
  background: #fce7e5;
  color: #b14a2f;
}

.error-text,
.success-text,
.muted-text {
  display: block;
  margin-top: 12rpx;
  line-height: 1.6;
}

.error-text {
  color: #b14a2f;
}

.success-text {
  color: #2f7a49;
}

.muted-text {
  color: #7b8794;
}

.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f3e1cf;
  color: #9d6734;
  font-size: 24rpx;
}

.list-item {
  margin-bottom: 16rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #f7f9fb;
}

.list-title {
  display: block;
  margin-bottom: 8rpx;
  font-weight: 600;
}

.list-meta {
  display: block;
  margin-top: 6rpx;
  color: #6c7a89;
  font-size: 24rpx;
}

.badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f3e1cf;
  color: #9d6734;
  font-size: 24rpx;
}

.muted-card {
  background: #f7f9fb;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.pill-button {
  border-radius: 999rpx;
}

.ghost-button {
  background: #eef2f6;
  color: #425466;
}
