<view class="page">
  <view class="hero">
    <text class="eyebrow">Check In</text>
    <text class="title">现场签到</text>
    <text class="desc">当前签到改为提交申请制，提交后需要老师确认，后台才会显示已到场。</text>
  </view>

  <view class="panel">
    <text class="badge">{{statusLabel}}</text>
    <text class="section-title">{{competitionTitle}}</text>
    <text class="section-desc">{{competitionDesc}}</text>
    <text class="muted-text">{{statusDesc}}</text>
    <text wx:if="{{checkedAt}}" class="success-text">申请时间：{{checkedAt}}</text>
    <text wx:if="{{reviewedAt}}" class="success-text">处理时间：{{reviewedAt}}</text>
    <text wx:if="{{reviewRemark}}" class="error-text">驳回原因：{{reviewRemark}}</text>
    <text wx:if="{{error}}" class="error-text">{{error}}</text>

    <view class="tip-list">
      <view wx:for="{{tips}}" wx:key="*this" class="list-item">
        <text>{{item}}</text>
      </view>
    </view>

    <button class="primary-btn" loading="{{submitting}}" disabled="{{loading || submitting || !canSubmit}}" bindtap="submitCheckin">
      {{submitting ? '提交中...' : submitButtonText}}
    </button>
  </view>
</view>
