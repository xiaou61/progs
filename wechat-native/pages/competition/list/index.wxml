<view class="page">
  <view class="hero">
    <text class="eyebrow">Competition</text>
    <text class="title">{{titleText}}</text>
    <text class="desc">{{descText}}</text>
  </view>

  <view wx:if="{{loading}}" class="state-card">
    <text>正在加载比赛数据...</text>
  </view>

  <view wx:elif="{{error}}" class="state-card">
    <text class="error-text">{{error}}</text>
  </view>

  <view wx:elif="{{competitions.length === 0}}" class="state-card">
    <text>{{emptyText}}</text>
  </view>

  <view wx:else class="list">
    <view wx:for="{{competitions}}" wx:key="id" class="panel" data-id="{{item.id}}" bindtap="openCompetitionDetail">
      <text class="section-title">{{item.title}}</text>
      <text class="section-desc">{{item.description}}</text>
      <text class="list-meta">{{item.statusLabel}} · 名额 {{item.quota}}</text>
      <text class="list-meta">参赛类型：{{item.participantTypeLabel}}</text>
      <text wx:if="{{item.participantType === 'STUDENT_ONLY'}}" class="list-meta">指导老师：{{item.advisorTeacherText}}</text>
      <text class="list-meta">报名时间：{{item.signupWindow}}</text>
      <text class="list-meta action-text">查看详情并继续操作</text>
    </view>
  </view>
</view>
