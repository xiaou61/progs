<view class="page">
  <view class="hero">
    <text class="eyebrow">Result</text>
    <text class="title">比赛结果</text>
    <text class="desc">当前已接入真实结果接口，可直接查看成绩、奖项、名次、评审意见和电子奖状编号。</text>
  </view>

  <view wx:if="{{loading}}" class="state-card">
    <text>正在加载比赛结果...</text>
  </view>

  <view wx:elif="{{error}}" class="state-card">
    <text class="error-text">{{error}}</text>
  </view>

  <view wx:elif="{{awards.length === 0}}" class="state-card">
    <text>当前还没有已发布的比赛结果。</text>
  </view>

  <view wx:else class="result-list">
    <view wx:for="{{awards}}" wx:key="id" class="panel">
      <text class="section-title">{{item.title}}</text>
      <text class="section-desc">{{item.awardName}} · {{item.rankText}}</text>
      <text class="list-meta">成绩 {{item.score}} · 奖励积分 {{item.points}}</text>
      <text wx:if="{{item.reviewerName}}" class="list-meta">评审老师 {{item.reviewerName}}</text>
      <text wx:if="{{item.reviewComment}}" class="list-meta">评审意见：{{item.reviewComment}}</text>
      <view wx:if="{{item.certificateNo}}" class="certificate-card">
        <text class="list-title">{{item.certificateTitle}}</text>
        <text class="list-meta">编号 {{item.certificateNo}}</text>
      </view>
      <text class="list-meta">{{item.publishedAtText}}</text>
    </view>
  </view>
</view>
