.switch-item {
  margin-bottom: 18rpx;
}

.time-picker-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.picker-chip {
  min-height: 88rpx;
  padding: 18rpx 22rpx;
  border-radius: 18rpx;
  background: #f7fafc;
  border: 2rpx solid rgba(207, 218, 228, 0.78);
  box-sizing: border-box;
}

.picker-caption {
  display: block;
  margin-bottom: 8rpx;
  color: #7b8794;
  font-size: 22rpx;
}

.picker-value {
  display: block;
  color: #1f2d3d;
  font-weight: 600;
}

.competition-item {
  margin-bottom: 16rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #f7f9fb;
  border: 2rpx solid #e2e8ef;
}

.competition-item-active {
  border-color: #c86c31;
  box-shadow: 0 12rpx 28rpx rgba(200, 108, 49, 0.12);
}
