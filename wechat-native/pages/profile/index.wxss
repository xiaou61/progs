.profile-hero {
  margin-bottom: 20rpx;
}

.summary-panel {
  margin-bottom: 24rpx;
}

.profile-grid {
  margin-top: 16rpx;
}

.switch-group {
  display: grid;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.switch-item {
  margin-bottom: 0;
  padding: 18rpx 0;
  border-bottom: 2rpx solid rgba(236, 241, 246, 0.88);
}

.section-divider {
  height: 2rpx;
  margin: 12rpx 0 24rpx;
  background: rgba(236, 241, 246, 0.92);
}

.feedback-textarea {
  min-height: 120rpx;
}

.upload-list {
  margin-top: 16rpx;
}

.upload-item {
  position: relative;
  padding-right: 120rpx;
}

.upload-remove-btn {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  margin-top: 0;
}

.danger-panel {
  border: 2rpx solid rgba(177, 74, 47, 0.18);
}

.danger-input {
  background: #fdf4f1;
}
