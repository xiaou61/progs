<view class="page login-page">
  <view class="hero login-hero">
    <view class="hero-copy">
      <text class="eyebrow">Campus Competition</text>
      <text class="title">账号登录</text>
      <text class="desc">本系统采用后台开通账号模式。请选择身份后，使用学号和密码进入系统。</text>
    </view>

    <view class="login-tip-card">
      <text class="tip-title">登录说明</text>
      <text class="tip-text">账号由管理员创建</text>
      <text class="tip-text">首次登录后可在个人中心修改密码</text>
    </view>
  </view>

  <view class="panel login-form">
    <view class="button-row compact-row">
      <button class="secondary-btn pill-button" data-role="STUDENT" bindtap="applyPreset">学生演示账号</button>
      <button class="secondary-btn pill-button" data-role="TEACHER" bindtap="applyPreset">老师演示账号</button>
    </view>

    <view class="field">
      <text class="label">身份</text>
      <radio-group class="role-group" bindchange="changeRole">
        <label class="role-option {{roleCode === 'STUDENT' ? 'active' : ''}}">
          <radio value="STUDENT" checked="{{roleCode === 'STUDENT'}}" color="#c86c31" />
          <text>学生登录</text>
        </label>
        <label class="role-option {{roleCode === 'TEACHER' ? 'active' : ''}}">
          <radio value="TEACHER" checked="{{roleCode === 'TEACHER'}}" color="#c86c31" />
          <text>老师登录</text>
        </label>
      </radio-group>
    </view>

    <view class="field">
      <text class="label">学号</text>
      <input class="input" value="{{studentNo}}" data-field="studentNo" placeholder="请输入学号" bindinput="updateField" />
    </view>

    <view class="field">
      <text class="label">密码</text>
      <input class="input" value="{{password}}" data-field="password" password placeholder="请输入密码" bindinput="updateField" />
    </view>

    <view class="login-meta">
      <text class="mini-badge">{{roleCode === 'TEACHER' ? '老师入口' : '学生入口'}}</text>
      <text class="muted-text">当前仅提供登录，不提供用户端自助注册。</text>
    </view>

    <text wx:if="{{error}}" class="error-text">{{error}}</text>

    <button class="primary-btn" loading="{{loading}}" disabled="{{loading}}" bindtap="submitLogin">
      {{loading ? '登录中...' : '登录进入系统'}}
    </button>
  </view>
</view>
