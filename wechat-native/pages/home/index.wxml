<view class="page">
  <view class="hero home-hero">
    <view>
      <text class="eyebrow">Campus Competition</text>
      <text class="title">欢迎回来</text>
      <text class="desc">{{roleCode === 'TEACHER' ? '老师工作台' : '学生工作台'}} · {{displayName}}</text>
    </view>
    <button class="ghost-button pill-button" size="mini" bindtap="logout">退出登录</button>
  </view>

  <view class="panel task-panel">
    <view class="meta-row">
      <text class="section-title">今日任务</text>
      <text class="mini-badge">{{loading ? '同步中' : '待处理'}}</text>
    </view>
    <text class="section-desc">{{taskProgress}}</text>
    <text wx:if="{{error}}" class="error-text">{{error}}</text>
    <text wx:if="{{success}}" class="success-text">{{success}}</text>
    <view class="button-row">
      <button class="primary-btn pill-button" loading="{{loading}}" disabled="{{loading}}" bindtap="handleDailyCheckin">
        {{loading ? '处理中...' : checkinLabel}}
      </button>
      <button class="secondary-btn pill-button" bindtap="openCompetitionList">{{shareLabel}}</button>
    </view>
  </view>

  <view wx:if="{{overviewCards.length > 0}}" class="panel">
    <view class="meta-row">
      <text class="section-title">我的进度</text>
      <text class="list-meta">比赛参与与成果汇总</text>
    </view>
    <view class="grid-2 overview-grid">
      <view wx:for="{{overviewCards}}" wx:key="label" class="list-item stat-card">
        <text class="list-title">{{item.value}}</text>
        <text class="list-meta">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="panel">
    <view class="meta-row">
      <text class="section-title">常用入口</text>
      <text class="list-meta">优先展示当前身份最常用功能</text>
    </view>
    <view class="menu-list">
      <view wx:for="{{menuCards}}" wx:key="key" class="menu-card" data-key="{{item.key}}" bindtap="openMenu">
        <text class="menu-title">{{item.title}}</text>
        <text class="menu-meta">点击进入 {{item.title}}</text>
      </view>
    </view>
  </view>
</view>
