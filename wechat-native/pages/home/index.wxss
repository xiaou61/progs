.home-hero {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: flex-start;
}

.task-panel {
  margin-top: 8rpx;
}

.overview-grid {
  margin-top: 18rpx;
}

.stat-card {
  background: linear-gradient(180deg, #fbfdff, #f5f8fb);
}

.clickable-card {
  border: 2rpx solid rgba(233, 239, 245, 0.95);
}

.menu-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.menu-card {
  padding: 26rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fbfdff, #f5f8fb);
  border: 2rpx solid rgba(233, 239, 245, 0.95);
}

.menu-title {
  display: block;
  margin-bottom: 8rpx;
  color: #1d2a3a;
  font-size: 30rpx;
  font-weight: 600;
}

.menu-meta {
  display: block;
  color: #6c7a89;
  font-size: 24rpx;
}

@media (max-width: 520rpx) {
  .menu-list {
    grid-template-columns: 1fr;
  }
}
