.home-hero {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: flex-start;
}

.task-panel {
  margin-top: 8rpx;
}

.banner-swiper {
  height: 220rpx;
  margin-bottom: 18rpx;
}

.banner-card {
  height: 100%;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at right top, rgba(235, 185, 120, 0.18), transparent 34%),
    linear-gradient(135deg, rgba(255, 249, 242, 0.98), rgba(248, 251, 255, 0.96));
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-copy {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 28rpx;
  background: linear-gradient(180deg, rgba(20, 28, 38, 0), rgba(20, 28, 38, 0.62));
}

.banner-eyebrow {
  margin-bottom: 10rpx;
  color: rgba(255, 236, 215, 0.92);
  font-size: 22rpx;
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

.banner-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
}

.banner-desc {
  margin-top: 14rpx;
  color: rgba(244, 247, 251, 0.88);
  font-size: 24rpx;
}

.overview-grid {
  margin-top: 18rpx;
}

.stat-card {
  background: linear-gradient(180deg, #fbfdff, #f5f8fb);
}

.clickable-card {
  border: 2rpx solid rgba(233, 239, 245, 0.95);
}

.menu-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.menu-card {
  padding: 26rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fbfdff, #f5f8fb);
  border: 2rpx solid rgba(233, 239, 245, 0.95);
}

.menu-title {
  display: block;
  margin-bottom: 8rpx;
  color: #1d2a3a;
  font-size: 30rpx;
  font-weight: 600;
}

.menu-meta {
  display: block;
  color: #6c7a89;
  font-size: 24rpx;
}

@media (max-width: 520rpx) {
  .menu-list {
    grid-template-columns: 1fr;
  }
}
